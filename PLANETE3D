<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Petite Planète — Paris 3D</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { 
    width: 100%; 
    height: 100%;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    overflow: hidden;
  }

 #canvas-container {
    position: fixed;
    bottom: 0;       /* Colle l'élément en bas */
    left: 0;
    width: 100%;
    height: 60vh;    /* Ajustez cette hauteur (ex: 60% de l'écran) */
    z-index: 1;
    /* Optionnel : dégradé pour mieux intégrer avec le fond */
    background: linear-gradient(to top, #ffa077 0%, transparent 100%);
  }

  #scene {
    display: block;
    width: 100%;
    height: 100%;
    touch-action: none;
    cursor: default;
  }
</style>
</head>
<body>

<div id="canvas-container">
  <canvas id="scene"></canvas>
</div>

<script>
function start() {
  if (!window.THREE) { setTimeout(start, 30); return; }

    const THREE = window.THREE;
    const canvas = document.getElementById("scene");
    const R = 10;

    // ---- seeded rng ----
    let s = 1337;
    const rnd = () => { s = (s * 1664525 + 1013904223) >>> 0; return s / 4294967296; };
    const range = (a, b) => a + (b - a) * rnd();

    // ---- renderer / scene / camera ----
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(34, 1, 0.1, 200);
    let camDist = 35;

    // ---- lights (warm sunset) ----
    scene.add(new THREE.AmbientLight(0xfff2e0, 0.85));
    const sun = new THREE.DirectionalLight(0xffe6c2, 1.25);
    sun.position.set(14, 22, 12);
    sun.castShadow = true;
    sun.shadow.mapSize.set(2048, 2048);
    sun.shadow.camera.near = 1; sun.shadow.camera.far = 80;
    sun.shadow.camera.left = -22; sun.shadow.camera.right = 22;
    sun.shadow.camera.top = 22; sun.shadow.camera.bottom = -22;
    sun.shadow.bias = -0.0004;
    scene.add(sun);
    const fill = new THREE.DirectionalLight(0xbcd0ff, 0.35);
    fill.position.set(-12, -6, -10);
    scene.add(fill);

    // ---- world group (rotates) ----
    const world = new THREE.Group();
    scene.add(world);

    // ---- incliner la sphère vers nous ----
    world.rotation.z = 0;
    world.rotation.x = 0.45;

    // ---- helpers ----
    const UP = new THREE.Vector3(0, 1, 0);
    const tmpQ = new THREE.Quaternion();
    const posOnSphere = (lat, lon, r) => {
      const phi = (90 - lat) * Math.PI / 180;
      const th = lon * Math.PI / 180;
      return new THREE.Vector3(
        r * Math.sin(phi) * Math.cos(th),
        r * Math.cos(phi),
        r * Math.sin(phi) * Math.sin(th)
      );
    };
    const orient = (obj, normal, spin) => {
      obj.quaternion.setFromUnitVectors(UP, normal.clone().normalize());
      if (spin) { tmpQ.setFromAxisAngle(normal.clone().normalize(), spin); obj.quaternion.premultiply(tmpQ); }
    };

    // ---- the planet (top hemisphere dome only) ----
    const land = new THREE.Mesh(
      new THREE.SphereGeometry(R, 96, 48, 0, Math.PI * 2, 0, Math.PI / 2),
      new THREE.MeshStandardMaterial({ color: 0x5f8f3e, roughness: 0.95, metalness: 0 })
    );
    land.receiveShadow = true;
    world.add(land);
    // flat cut bottom (soil cross-section)
    const cut = new THREE.Mesh(
      new THREE.CircleGeometry(R, 96),
      new THREE.MeshStandardMaterial({ color: 0x6b5333, roughness: 1, side: THREE.DoubleSide })
    );
    cut.rotation.x = Math.PI / 2;
    cut.position.y = 0;
    world.add(cut);

    // ---- materials ----
    const stoneCols = [0xd8ccb4, 0xcdbfa6, 0xc7bda9, 0xbcae93, 0xd2c7b0, 0xc2b69c];
    const roofCol = 0x6f7682;
    const stoneMats = stoneCols.map(c => new THREE.MeshStandardMaterial({ color: c, roughness: 0.9 }));
    const roofMat = new THREE.MeshStandardMaterial({ color: roofCol, roughness: 0.8 });
    const slateMat = new THREE.MeshStandardMaterial({ color: 0x4d535d, roughness: 0.7 });
    const creamMat = new THREE.MeshStandardMaterial({ color: 0xeae3d2, roughness: 0.85 });
    const whiteMat = new THREE.MeshStandardMaterial({ color: 0xb6ad9a, roughness: 0.75 });
    const ironMat = new THREE.MeshStandardMaterial({ color: 0x6b5a44, roughness: 0.6, metalness: 0.3 });
    const treeMat = new THREE.MeshStandardMaterial({ color: 0x3c7a2e, roughness: 1 });
    const treeMat2 = new THREE.MeshStandardMaterial({ color: 0x4f9438, roughness: 1 });
    const waterMat = new THREE.MeshStandardMaterial({ color: 0x5b93ab, roughness: 0.22, metalness: 0.4, side: THREE.DoubleSide });
    const roadMat = new THREE.MeshStandardMaterial({ color: 0x8c8779, roughness: 1 });
    const glassMat = new THREE.MeshStandardMaterial({ color: 0xbfd6e0, roughness: 0.15, metalness: 0.4, transparent: true, opacity: 0.75 });

    // ---- procedural Parisian facades with windows ----
    const makeFacade = (baseHex) => {
      const cw = 96, ch = 168;
      const c = document.createElement('canvas'); c.width = cw; c.height = ch;
      const x = c.getContext('2d');
      x.fillStyle = '#' + baseHex.toString(16).padStart(6, '0'); x.fillRect(0, 0, cw, ch);
      const e = document.createElement('canvas'); e.width = cw; e.height = ch;
      const ex = e.getContext('2d'); ex.fillStyle = '#000'; ex.fillRect(0, 0, cw, ch);
      const cols = 4, rows = 7, mx = 12, my = 14;
      const gw = (cw - mx * 2) / cols, gh = (ch - my * 2) / rows;
      const winW = gw * 0.6, winH = gh * 0.62;
      for (let r = 0; r < rows; r++) {
        for (let col = 0; col < cols; col++) {
          const px = mx + col * gw + (gw - winW) / 2;
          const py = my + r * gh + (gh - winH) / 2;
          const lit = rnd() < 0.2;
          x.fillStyle = lit ? '#ffe4ab' : (rnd() < 0.5 ? '#586271' : '#69727e');
          x.fillRect(px, py, winW, winH);
          x.strokeStyle = 'rgba(40,34,26,0.22)'; x.lineWidth = 2; x.strokeRect(px, py, winW, winH);
          if (lit) { ex.fillStyle = '#ffcf8c'; ex.fillRect(px, py, winW, winH); }
        }
      }
      return new THREE.MeshStandardMaterial({
        map: new THREE.CanvasTexture(c),
        emissive: 0xffce8a, emissiveMap: new THREE.CanvasTexture(e), emissiveIntensity: 0.85,
        roughness: 0.85
      });
    };
    const facadeMats = [];
    for (let i = 0; i < 8; i++) facadeMats.push(makeFacade(stoneCols[i % stoneCols.length]));

    const boxGeo = new THREE.BoxGeometry(1, 1, 1);
    const coneGeo = new THREE.ConeGeometry(0.5, 1, 4);
    const treeGeo = new THREE.IcosahedronGeometry(0.5, 0);

    const placeBox = (parent, lat, lon, w, h, d, mat, spin) => {
      const m = new THREE.Mesh(boxGeo, mat);
      m.scale.set(w, h, d);
      const p = posOnSphere(lat, lon, R);
      const n = p.clone().normalize();
      m.position.copy(p).addScaledVector(n, h / 2);
      orient(m, n, spin);
      m.castShadow = true; m.receiveShadow = true;
      parent.add(m);
      return m;
    };

    const buildPath = (waypoints, width, mat, lift) => {
      const pts = waypoints.map(w => posOnSphere(w[0], w[1], R + (lift || 0.02)));
      const curve = new THREE.CatmullRomCurve3(pts);
      const N = Math.max(24, waypoints.length * 14);
      const sampled = curve.getPoints(N);
      const g = new THREE.Group();
      for (let i = 0; i < sampled.length - 1; i++) {
        const a = sampled[i], b = sampled[i + 1];
        const mid = a.clone().add(b).multiplyScalar(0.5);
        const len = a.distanceTo(b) * 2.3;
        const seg = new THREE.Mesh(boxGeo, mat);
        seg.scale.set(width, 0.06, len);
        const n = mid.clone().normalize();
        mid.copy(n).multiplyScalar(R + (lift || 0.02));
        seg.position.copy(mid);
        const fwd = b.clone().sub(a).normalize();
        const right = new THREE.Vector3().crossVectors(fwd, n).normalize();
        const f2 = new THREE.Vector3().crossVectors(n, right).normalize();
        const mtx = new THREE.Matrix4().makeBasis(right, n, f2);
        seg.quaternion.setFromRotationMatrix(mtx);
        seg.receiveShadow = true;
        g.add(seg);
      }
      world.add(g);
      return g;
    };

    const buildRiver = (waypoints, width, mat, lift, closed) => {
      const pts = waypoints.map(w => posOnSphere(w[0], w[1], R));
      const curve = new THREE.CatmullRomCurve3(pts, !!closed, 'catmullrom', 0.5);
      const samples = curve.getPoints(440);
      if (closed) samples.pop();
      const n = samples.length;
      const Rr = R + (lift || 0.04);
      const verts = [], idx = [];
      for (let i = 0; i < n; i++) {
        const p = samples[i];
        const prev = samples[(i - 1 + n) % n];
        const nxt = samples[(i + 1) % n];
        const normal = p.clone().normalize();
        const tan = nxt.clone().sub(prev).normalize();
        const side = new THREE.Vector3().crossVectors(tan, normal).normalize();
        const L = p.clone().addScaledVector(side, width / 2).normalize().multiplyScalar(Rr);
        const Rt = p.clone().addScaledVector(side, -width / 2).normalize().multiplyScalar(Rr);
        verts.push(L.x, L.y, L.z, Rt.x, Rt.y, Rt.z);
      }
      const segs = closed ? n : n - 1;
      for (let i = 0; i < segs; i++) {
        const a = (i % n) * 2, b = (i % n) * 2 + 1, c = ((i + 1) % n) * 2, d = ((i + 1) % n) * 2 + 1;
        idx.push(a, b, c, b, d, c);
      }
      const geo = new THREE.BufferGeometry();
      geo.setAttribute('position', new THREE.Float32BufferAttribute(verts, 3));
      geo.setIndex(idx);
      geo.computeVertexNormals();
      const m = new THREE.Mesh(geo, mat);
      m.receiveShadow = true;
      world.add(m);
      return m;
    };

    // ============ THE SEINE ============
    buildRiver([
      [12, -180], [15, -150], [12, -122], [16, -96], [23, -70], [31, -44],
      [34, -18], [28, 2], [33, 24], [25, 48], [17, 72], [13, 96], [15, 124], [11, 152]
    ], 1.05, waterMat, 0.06, true);

    // ============ ROADS ============
    const roads = [
      [[60, -40], [45, -25], [30, -15], [18, -5], [8, 8], [5, 18]],
      [[55, 30], [42, 18], [30, 5], [22, -10], [16, -28], [12, -48]],
      [[40, -60], [42, -30], [44, 0], [42, 30], [38, 60]],
      [[70, 0], [50, 5], [30, 8], [12, 10], [5, 12]],
      [[25, -80], [28, -50], [30, -20], [33, 10], [35, 40], [34, 70]],
      [[18, -30], [12, -5], [10, 25], [14, 45]]
    ];
    roads.forEach(r => buildPath(r, 0.42, roadMat, 0.03));

    buildPath([[44, 152], [36, 150.5], [27, 149], [17, 148]], 0.9, roadMat, 0.045);
    buildPath([[44, 152], [52, 150], [61, 149]], 0.46, roadMat, 0.04);
    buildPath([[44, 152], [47, 161], [50, 170]], 0.46, roadMat, 0.04);
    buildPath([[44, 152], [41, 143], [39, 134]], 0.46, roadMat, 0.04);

    // ============ BUILDINGS ============
    const cityCenter = { lat: 50, lon: 5 };
    const angDist = (lat, lon) => {
      const a = posOnSphere(lat, lon, 1), b = posOnSphere(cityCenter.lat, cityCenter.lon, 1);
      return a.angleTo(b);
    };
    const clearZones = [[44, -28, 0.17], [44, 152, 0.18], [46, -118, 0.2], [46, 62, 0.2], [50, 38, 0.16], [30, 30, 0.15], [28, -8, 0.15], [24, -46, 0.12], [16, 14, 0.17]];
    const inMonument = (la, lo) => {
      const a = posOnSphere(la, lo, 1);
      return clearZones.some(z => a.angleTo(posOnSphere(z[0], z[1], 1)) < z[2]);
    };
    let placed = 0, attempts = 0;
    while (placed < 230 && attempts < 6000) {
      attempts++;
      const lat = range(3, 88);
      const lon = range(-180, 180);
      if (inMonument(lat, lon)) continue;
      const d = angDist(lat, lon);
      const prob = Math.max(0, 1 - d / 2.3);
      if (rnd() > prob * prob) continue;
      const big = rnd();
      const h = range(0.35, 0.7) + (big > 0.92 ? range(0.5, 1.2) : 0);
      const w = range(0.42, 0.85), dp = range(0.42, 0.85);
      const mat = facadeMats[(rnd() * facadeMats.length) | 0];
      const spin = range(0, Math.PI * 2);
      placeBox(world, lat, lon, w, h, dp, mat, spin);
      const roof = new THREE.Mesh(coneGeo, rnd() > 0.5 ? slateMat : roofMat);
      const p = posOnSphere(lat, lon, R);
      const n = p.clone().normalize();
      const rh = Math.max(w, dp) * range(0.4, 0.7);
      roof.scale.set(w * 1.02, rh, dp * 1.02);
      roof.position.copy(p).addScaledVector(n, h + rh / 2);
      orient(roof, n, spin + Math.PI / 4);
      roof.castShadow = true;
      world.add(roof);
      placed++;
    }

    // ============ TREES ============
    let tplaced = 0, ta = 0;
    while (tplaced < 320 && ta < 7000) {
      ta++;
      const lat = range(3, 88);
      const lon = range(-180, 180);
      if (inMonument(lat, lon)) continue;
      const d = angDist(lat, lon);
      const prob = Math.min(1, 0.25 + d / 2.6);
      if (rnd() > prob * 0.8) continue;
      const p = posOnSphere(lat, lon, R);
      const n = p.clone().normalize();
      const sc = range(0.35, 0.7);
      const tr = new THREE.Mesh(treeGeo, rnd() > 0.5 ? treeMat : treeMat2);
      tr.scale.setScalar(sc);
      tr.position.copy(p).addScaledVector(n, sc * 0.55);
      orient(tr, n, range(0, 6));
      tr.castShadow = true; tr.receiveShadow = true;
      world.add(tr);
      tplaced++;
    }

    // ============ LANDMARKS ============
    const dropGroup = (g, lat, lon, spin) => {
      const p = posOnSphere(lat, lon, R);
      const n = p.clone().normalize();
      g.position.copy(p);
      orient(g, n, spin || 0);
      g.traverse(o => { if (o.isMesh) { o.castShadow = true; o.receiveShadow = true; } });
      world.add(g);
    };
    const placeFacing = (g, lat, lon, az) => {
      const p = posOnSphere(lat, lon, R);
      const up = p.clone().normalize();
      let north = new THREE.Vector3(0, 1, 0).addScaledVector(up, -up.y).normalize();
      if (!isFinite(north.x) || north.lengthSq() < 1e-6) north.set(0, 0, 1);
      const east = new THREE.Vector3().crossVectors(up, north).normalize();
      const face = north.clone().multiplyScalar(Math.cos(az)).addScaledVector(east, Math.sin(az)).normalize();
      const right = new THREE.Vector3().crossVectors(up, face).normalize();
      g.position.copy(p);
      g.quaternion.setFromRotationMatrix(new THREE.Matrix4().makeBasis(right, up, face));
      g.traverse(o => { if (o.isMesh) { o.castShadow = true; o.receiveShadow = true; } });
      world.add(g);
    };
    const mkBox = (w, h, d, y, mat) => {
      const m = new THREE.Mesh(boxGeo, mat); m.scale.set(w, h, d); m.position.y = y; return m;
    };

    // Landmarks (Eiffel Tower, Arc de Triomphe, Sacré-Cœur, etc.)
    (() => {
      const g = new THREE.Group();
      const strut = (ax, ay, az, bx, by, bz, t) => {
        const a = new THREE.Vector3(ax, ay, az), b = new THREE.Vector3(bx, by, bz);
        const m = new THREE.Mesh(boxGeo, ironMat);
        m.scale.set(t, a.distanceTo(b), t);
        m.position.copy(a).add(b).multiplyScalar(0.5);
        m.quaternion.setFromUnitVectors(UP, b.clone().sub(a).normalize());
        g.add(m);
      };
      const corners = [[1, 1], [1, -1], [-1, 1], [-1, -1]];
      const b0 = 1.55, h1 = 1.35, p1 = 0.8, h2 = 2.8, p2 = 0.34, hTop = 3.9;
      corners.forEach(([sx, sz]) => {
        const mx = sx * 1.12, mz = sz * 1.12, my = h1 * 0.5;
        strut(sx * b0, 0, sz * b0, mx, my, mz, 0.17);
        strut(mx, my, mz, sx * p1, h1, sz * p1, 0.13);
      });
      [-1, 1].forEach(sz => {
        const arc = new THREE.Mesh(new THREE.TorusGeometry(0.85, 0.07, 6, 18, Math.PI), ironMat);
        arc.position.set(0, h1 * 0.55, sz * b0 * 0.78); g.add(arc);
      });
      const plat = (y, half, th) => { const m = new THREE.Mesh(boxGeo, ironMat); m.scale.set(half * 2 + 0.22, th, half * 2 + 0.22); m.position.y = y; g.add(m); };
      plat(h1, p1 + 0.05, 0.17);
      corners.forEach(([sx, sz]) => strut(sx * p1, h1, sz * p1, sx * p2, h2, sz * p2, 0.11));
      plat(h2, p2 + 0.05, 0.13);
      const up = new THREE.Mesh(new THREE.CylinderGeometry(0.05, p2 * 0.95, hTop - h2, 4), ironMat);
      up.position.y = (h2 + hTop) / 2; up.rotation.y = Math.PI / 4; g.add(up);
      const cab = new THREE.Mesh(boxGeo, ironMat); cab.scale.set(0.18, 0.18, 0.18); cab.position.y = hTop; g.add(cab);
      const ant = new THREE.Mesh(new THREE.CylinderGeometry(0.012, 0.05, 0.9, 6), ironMat);
      ant.position.y = hTop + 0.55; g.add(ant);
      g.scale.setScalar(1.08);
      dropGroup(g, 44, -28, 0.4);
    })();

    (() => {
      const g = new THREE.Group();
      const cw = 520, ch = 300, m = 18;
      const c = document.createElement('canvas'); c.width = cw; c.height = ch;
      const x = c.getContext('2d');
      x.fillStyle = '#141414'; x.fillRect(0, 0, cw, ch);
      x.strokeStyle = '#f2f0ea'; x.lineWidth = 4;
      x.strokeRect(m, m, cw - 2 * m, ch - 2 * m);
      x.beginPath(); x.moveTo(cw / 2, m); x.lineTo(cw / 2, ch - m); x.stroke();
      x.beginPath(); x.arc(cw / 2, ch / 2, 42, 0, Math.PI * 2); x.stroke();
      const keyW = 96, keyH = 96;
      x.strokeRect(m, ch / 2 - keyH / 2, keyW, keyH);
      x.beginPath(); x.arc(m + keyW, ch / 2, 36, 0, Math.PI * 2); x.stroke();
      x.beginPath(); x.arc(m, ch / 2, 120, -Math.PI / 2, Math.PI / 2); x.stroke();
      x.strokeRect(cw - m - keyW, ch / 2 - keyH / 2, keyW, keyH);
      x.beginPath(); x.arc(cw - m - keyW, ch / 2, 36, 0, Math.PI * 2); x.stroke();
      x.beginPath(); x.arc(cw - m, ch / 2, 120, Math.PI / 2, Math.PI * 1.5); x.stroke();
      x.fillStyle = 'rgba(245,243,236,0.95)';
      x.font = 'bold 118px Helvetica, Arial, sans-serif';
      x.textAlign = 'center'; x.textBaseline = 'middle';
      x.fillText('CDM', cw / 2, ch / 2 + 4);
      const tex = new THREE.CanvasTexture(c);
      const blackMat = new THREE.MeshStandardMaterial({ color: 0x141414, roughness: 0.8 });
      g.add(mkBox(2.7, 0.08, 1.56, 0.04, blackMat));
      const top = new THREE.Mesh(new THREE.PlaneGeometry(2.62, 1.5), new THREE.MeshStandardMaterial({ map: tex, roughness: 0.65 }));
      top.rotation.x = -Math.PI / 2; top.position.y = 0.085; g.add(top);
      const postMat = new THREE.MeshStandardMaterial({ color: 0x2a2a2a, roughness: 0.6 });
      const boardMat = new THREE.MeshStandardMaterial({ color: 0xf2f0ea, roughness: 0.6 });
      const rimMat = new THREE.MeshStandardMaterial({ color: 0xe07b2a, roughness: 0.5, metalness: 0.3 });
      [-1, 1].forEach(s => {
        const post = new THREE.Mesh(new THREE.CylinderGeometry(0.035, 0.035, 0.55, 8), postMat);
        post.position.set(s * 1.32, 0.28, 0); g.add(post);
        const board = new THREE.Mesh(boxGeo, boardMat);
